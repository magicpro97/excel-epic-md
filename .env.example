# LLM Provider: gemini | github | openai | azure | openrouter | ollama
LLM_PROVIDER=gemini

# === Gemini (default) ===
GEMINI_API_KEY=your_api_key_here
GEMINI_MODEL=gemini-1.5-pro

# === GitHub Models (uses your GitHub token) ===
# Get token: https://github.com/settings/tokens (needs "models" scope)
# GITHUB_TOKEN=ghp_xxxx
# GITHUB_MODEL=gpt-4o

# === OpenAI ===
# OPENAI_API_KEY=sk-xxxx
# OPENAI_MODEL=gpt-4o

# === Azure OpenAI (Enterprise SLA - 99.9% uptime) ===
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_API_KEY=xxxx
# AZURE_OPENAI_DEPLOYMENT=gpt-4o
# AZURE_OPENAI_API_VERSION=2024-02-15-preview

# === OpenRouter (unified API for Claude, Gemini, Llama, etc.) ===
# Get API key: https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-xxxx
# OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# === Ollama (local, free) ===
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# === Merge Step LLM (optional - for large context merging) ===
# LLM_MERGE_PROVIDER=gemini
# LLM_MERGE_MODEL=gemini-2.5-flash

# OCR confidence threshold (optional, default: 0.7)
OCR_CONFIDENCE_THRESHOLD=0.7

# Table detection (optional, default: true)
# DETECT_TABLES=true

# LibreOffice path (optional, auto-detect if not set)
# LIBREOFFICE_PATH=/usr/bin/libreoffice
